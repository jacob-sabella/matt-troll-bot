# Discord bot token from https://discord.com/developers/applications
DISCORD_TOKEN=your_bot_token_here

# Whisper model size: tiny, base, small, medium, large-v3
# Larger = more accurate but slower and more RAM
WHISPER_MODEL=base

# Device for Whisper inference: cpu, cuda, auto
WHISPER_DEVICE=auto

# Compute type: int8 (fastest), float16, float32
WHISPER_COMPUTE_TYPE=int8

# Silence threshold in seconds — audio is transcribed after this much silence
SILENCE_THRESHOLD=1.5

# Minimum audio duration in seconds before transcribing (avoids noise)
MIN_AUDIO_DURATION=0.5

# Text channel ID to post transcriptions to (optional — prints to stdout if unset)
TRANSCRIPT_CHANNEL_ID=
